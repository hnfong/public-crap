```python
def abbrev_num(x):
    if x < 1000:
        return str(x)
    
    suffixes = ['K', 'M', 'B', 'T']
    num = abs(x)
    suffix_index = 0
    
    while num >= 1000 and suffix_index < len(suffixes):
        num /= 1000
        suffix_index += 1
    
    # Format to 1 decimal place if needed, but ensure total length <= 4
    if num >= 10:
        # If it's 10 or more, we can't have a decimal point and still be <= 4 chars
        # e.g., 10.0K is 5 chars, so we round to integer
        result = f"{int(round(num))}{suffixes[suffix_index]}"
    else:
        # Format to 1 decimal place, then check length
        formatted = f"{num:.1f}"
        # Remove trailing zero if it's a whole number (e.g., 8.0 -> 8)
        if formatted.endswith('.0'):
            formatted = formatted[:-2]
        
        result = f"{formatted}{suffixes[suffix_index]}"
    
    # Final check: if result is longer than 4 chars, round to integer
    if len(result) > 4:
        result = f"{int(round(num))}{suffixes[suffix_index]}"
    
    # Handle negative numbers
    if x < 0:
        result = "-" + result
    
    return result
``` [end of text]


