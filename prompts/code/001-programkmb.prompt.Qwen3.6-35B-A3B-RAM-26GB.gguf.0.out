```java
import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.ArrayList;
import java.util.List;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Main {

    private static final long KILO = 1024;
    private static final long MEGA = KILO * KILO;
    private static final long GIGA = MEGA * KILO;

    public static void main(String[] args) {
        try {
            BufferedReader reader = new BufferedReader(new InputStreamReader(System.in));
            StringBuilder input = new StringBuilder();
            String line;
            while ((line = reader.readLine()) != null) {
                input.append(line).append("\n");
            }

            String text = input.toString();
            List<Double> values = extractNumbers(text);
            double totalBytes = 0;
            for (double val : values) {
                totalBytes += val;
            }

            System.out.printf("%.1f%n", totalBytes);
            System.out.printf("%.1f k%n", totalBytes / KILO);
            System.out.printf("%.1f M%n", totalBytes / MEGA);
            System.out.printf("%.1f G%n", totalBytes / GIGA);

        } catch (IOException e) {
            System.err.println("Error reading input: " + e.getMessage());
            System.exit(1);
        }
    }

    private static List<Double> extractNumbers(String text) {
        List<Double> values = new ArrayList<>();
        // Pattern to match numbers (with optional commas and decimal points) followed by optional suffix
        // Numbers can be like: 1.5G, 2K, 3M, 4.2G, 500,000K, 600M
        // We need to handle commas as thousand separators
        // Pattern explanation:
        // (\d{1,3}(?:,\d{3})*(?:\.\d+)?) - matches integer part with optional commas and optional decimal part
        // ([kKmMgG]?) - matches optional suffix
        Pattern pattern = Pattern.compile("(\\d{1,3}(?:,\\d{3})*(?:\\.\\d+)?)([kKmMgG]?)");
        Matcher matcher = pattern.matcher(text);

        while (matcher.find()) {
            String numberStr = matcher.group(1);
            String suffix = matcher.group(2);

            // Remove commas from the number string
            numberStr = numberStr.replace(",", "");

            double value;
            try {
                value = Double.parseDouble(numberStr);
            } catch (NumberFormatException e) {
                // Skip invalid numbers
                continue;
            }

            // Apply suffix multiplier
            if (suffix != null && !suffix.isEmpty()) {
                char suffixChar = suffix.charAt(0);
                switch (suffixChar) {
                    case 'k':
                    case 'K':
                        value *= KILO;
                        break;
                    case 'm':
                    case 'M':
                        value *= MEGA;
                        break;
                    case 'g':
                    case 'G':
                        value *= GIGA;
                        break;
                    default:
                        // No multiplier
                        break;
                }
            }

            values.add(value);
        }

        return values;
    }
}
