def abbrev_num(x):
    if x < 1000:
        return str(x)
    
    # Define magnitudes and their suffixes
    magnitudes = [
        (10**9, 'B'),
        (10**6, 'M'),
        (10**3, 'K'),
    ]
    
    for value, suffix in magnitudes:
        if x >= value:
            # Calculate the number in the current magnitude
            num = x / value
            
            # Try 1 decimal place first (e.g., "8.2K")
            # format(num, '.1f') gives 1 decimal. 
            # We strip trailing zeros and the dot if it's a whole number.
            s = "{:.1f}".format(num).rstrip('0').rstrip('.') + suffix
            
            # If the resulting string is <= 4 characters, return it
            if len(s) <= 4:
                return s
            
            # Otherwise, round to 0 decimal places to fit the 4 char limit (e.g., "75K")
            s = "{:.0f}".format(num) + suffix
            return s
            
    return str(x)
``` [end of text]


