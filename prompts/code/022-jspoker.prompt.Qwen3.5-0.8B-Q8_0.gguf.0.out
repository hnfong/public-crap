        <div class="action">
            <button onclick="moveCard('A', 'K')">A K</button>
            <button onclick="moveCard('K', 'Q')">K Q</button>
            <button onclick="moveCard('Q', 'J')">Q J</button>
            <button onclick="moveCard('J', '10')">J 10</button>
            <button onclick="moveCard('10', '9')">10 9</button>
            <button onclick="moveCard('9', '8')">9 8</button>
            <button onclick="moveCard('8', '7')">8 7</button>
