<!DOCTYPE html><html>
<head>
    <title>JS Poker</title>
    <style>
        body { font-family: sans-serif; background: #222; color: #eee; padding: 20px; }
        .game { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .hand { background: #333; padding: 15px; border-radius: 5px; margin-bottom: 10px; }
        .card { width: 50px; height: 70px; background: #444; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; margin: 5px; }
        .card.red { color: #ff0000; }
        .card.black { color: #000000; }
        .suit { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 10px; }
        .player { display: flex; gap: 10px; }
        .player-card { width: 50px; height: 70px; background: #444; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; margin: 5px; }
        .player-card.red { color: #ff0000; }
        .player-card.black { color: #000000; }
        .action { display: flex; gap: 10px; margin-top: 10px; }
        button { padding: 10px 20px; font-size: 16px; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 4px; }
        button:hover { background: #0056b3; }
        button:disabled { background: #ccc; cursor: not-allowed; }
        .message { margin-top: 10px; font-size: 14px; color: #aaa; }
    </style>
</head>
<body>
    <div class="game">
        <div class="hand">
            <div class="player">
                <div class="player-card">A</div>
                <div class="player-card">K</div>
