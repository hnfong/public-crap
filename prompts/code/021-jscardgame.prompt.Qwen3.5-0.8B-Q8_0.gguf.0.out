<!DOCTYPE html><html>
<head>
    <title>JS Solitaire Twist</title>
    <style>
        body { font-family: sans-serif; background: #222; color: #eee; padding: 20px; }
        .game { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .card { width: 80px; height: 120px; background: #444; border: 2px solid #666; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; color: white; cursor: pointer; position: relative; }
        .card.red { color: #d00; }
        .card.black { color: #000; }
        .card.selected { border-color: #fff; }
        .card.selected::after { content: '♥'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 40px; }
        .card.selected.black::after { content: '♦'; }
        .card.selected.red::after { content: '♥'; }
        .card.selected.black::after { content: '♦'; }
        .card.selected { box-shadow: 0 0 10px rgba(255,255,255,0.5); }
        .card.hidden { opacity: 0; pointer-events: none; }
        .controls { margin-top: 20px; display: flex; gap: 10px; }
        button { padding: 10px 20px; font-size: 16px; cursor: pointer; background: #333; color: white; border: 1px solid #555; }
        button:hover { background: #444; }
        button:disabled { background: #555; color: #888; cursor: not-allowed; }
    </style>
</head>
<body>
