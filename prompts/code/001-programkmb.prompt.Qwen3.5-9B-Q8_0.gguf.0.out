import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.ArrayList;
import java.util.List;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Main {
    public static void main(String[] args) {
        try (BufferedReader reader = new BufferedReader(new InputStreamReader(System.in))) {
            StringBuilder inputBuffer = new StringBuilder();
            String line;
            while ((line = reader.readLine()) != null) {
                inputBuffer.append(line).append("\n");
            }

            double totalBytes = 0.0;
            Pattern pattern = Pattern.compile(
                "([\\d,]+)\\.?([\\d]*)\\s*([kKmMgG])"
            );
            Matcher matcher = pattern.matcher(inputBuffer);

            while (matcher.find()) {
                String numberPart = matcher.group(1);
                String decimalPart = matcher.group(2);
                String suffix = matcher.group(3).toLowerCase();

                // Remove commas for parsing
                String cleanNumber = numberPart.replace(",", "");

                // Combine integer and decimal parts if decimal part exists
                String fullNumberStr = cleanNumber + (decimalPart.isEmpty() ? "" : "." + decimalPart);
                
                double value;
                try {
                    value = Double.parseDouble(fullNumberStr);
                } catch (NumberFormatException e) {
                    continue;
                }

                double multiplier = getMultiplier(suffix);
                if (multiplier == -1) {
                    continue;
                }

                totalBytes += value * multiplier;
            }

            // Calculate derived units
            double kb = totalBytes / 1024.0;
            double mb = kb / 1024.0;
            double gb = mb / 1024.0;

            // Print results formatted to one decimal place
            System.out.printf("%.1f%n", totalBytes);
            System.out.printf("%.1f k%n", kb);
            System.out.printf("%.1f M%n", mb);
            System.out.printf("%.1f G%n", gb);

        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    private static double getMultiplier(String suffix) {
        switch (suffix) {
            case "k":
            case "kilo":
                return 1024.0;
            case "m":
            case "mega":
                return 1024.0 * 1024.0;
            case "g":
            case "giga":
                return 1024.0 * 1024.0 * 1024.0;
            default:
                return -1;
        }
    }
} [end of text]


