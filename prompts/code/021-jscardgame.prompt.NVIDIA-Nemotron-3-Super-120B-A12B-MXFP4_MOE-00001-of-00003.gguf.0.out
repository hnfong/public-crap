const d=sh(s.flatMap(su=>v.map(va=>({s:su,v:va}))));
let t=[[],[],[],[],[],[],[]];for(let i=0;i<7;i++)for(let j=0;j<=i;j++)t[i].push(d.pop());
let w=[],f=[[],[],[],[]],st=d,sel=null;
function col(c){return c.s==='♥'||c.s==='♦'?0:1}
function vi(c){return v.indexOf(c.v)}
function r(){
const b=document.getElementById('b');
b.innerHTML='';
b.innerHTML+=`<div style="display:inline-block;margin:2px;"><div class="c" data-p="s" data-x="0" data-i="${st.length-1}" onclick="c(this)">${st.length?st[st.length-1].v+st[st.length-1].s:''}</div></div>`;
b.innerHTML+=`<div style="display:inline-block;margin:2px;"><div class="c" data-p="w" data-x="0" data-i="${w.length-1}" onclick="c(this)">${w.length?w[w.length-1].v+w[w.length-1].s:''}</div></div>`;
for(let i=0;i<4;i++){
const p=f[i];
b.innerHTML+=`<div style="display:inline-block;margin:2px;"><div class="c" data-p="f" data-x="${i}" data-i="${p.length-1}" onclick="c(this)">${p.length?p[p.length-1].v+p[p.length-1].s:''}</div></div>`;
}
for(let i=0;i<7;i++){
const p=t[i];
b.innerHTML+=`<div style="display:inline-block;margin:2px;">`;
for(let j=0;j<p.length;j++){
b.innerHTML+=`<div class="c" data-p="t" data-x="${i}" data-i="${j}" onclick="c(this)">${p[j].v+p[j].s}</div>`;
}
b.innerHTML+=`</div>`;
}
}
function c(e){
const tp=e.dataset.p;
const xi=+e.dataset.x;
const ci=+e.dataset.i;
let pile;
if(tp==='t')pile=t[xi];
else if(tp==='w')pile=w;
else if(tp==='f')pile=f[xi];
else if(tp==='s')pile=st;
else return;
if(pile.length===0){
if(tp==='s'&&st.length){w.push(st.pop());r();}
return;
}
if(ci!==pile.length-1)return;
if(!sel){sel={tp,xi,ci};e.style.background='#ff0';return;}
let card;
if(sel.tp==='t')card=t[sel.xi].splice(sel.ci,1)[0];
else if(sel.tp==='w')card=w.splice(sel.ci,1)[0];
else if(sel.tp==='f')card=f[sel.xi].splice(sel.ci,1)[0];
else return;
let ok=false;
if(tp==='t'){
if(pile.length===0)ok=true;
else{
const top=pile[pile.length-1];
ok=col(card)===col(top)&&vi(card)===vi(top)-1;
}
if(ok){pile.push(card);}
}
else if(tp==='f'){
if(pile.length===0)ok=vi(card)===0;
else{
const top=pile[pile.length-1];
ok=card.s===top.s&&vi(card)===vi(top)+1;
}
if(ok){pile.push(card);}
}
sel=null;
r();
}
</script>
</body>
</html> [end of text]


