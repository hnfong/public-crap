import java.io.*;
import java.util.*;
import java.util.regex.*;

public class NumberSum {
    public static void main(String[] args) {
        String input;
        try (Scanner scanner = new Scanner(System.in).useDelimiter("\\A")) {
            input = scanner.hasNext() ? scanner.next() : "";
        }

        Pattern p = Pattern.compile("\\d{1,3}(?:,\\d{3})*(?:\\.\\d+)?[kKmMgG]?");
        Matcher m = p.matcher(input);

        double total = 0.0;
        while (m.find()) {
            String token = m.group();
            char suffix = 0;
            String numPart;
            if (!token.isEmpty()) {
                char last = token.charAt(token.length() - 1);
                if (last == 'k' || last == 'K' || last == 'm' || last == 'M' || last == 'g' || last == 'G') {
                    suffix = last;
                    numPart = token.substring(0, token.length() - 1);
                } else {
                    numPart = token;
                }
            } else {
                continue;
            }
            numPart = numPart.replace(",", "");
            double value = Double.parseDouble(numPart);
            double multiplier;
            switch (Character.toLowerCase(suffix)) {
                case 'k': multiplier = 1024; break;
                case 'm': multiplier = 1024 * 1024; break;
                case 'g': multiplier = 1024 * 1024 * 1024; break;
                default: multiplier = 1; break;
            }
            total += value * multiplier;
        }

        double totalKB = total / 1024.0;
        double totalMB = total / (1024.0 * 1024.0);
        double totalGB = total / (1024.0 * 1024.0 * 1024.0);

        System.out.printf("%.1f%n", total);
        System.out.printf("%.1f k%n", totalKB);
        System.out.printf("%.1f M%n", totalMB);
        System.out.printf("%.1f G%n", totalGB);
    }
}
