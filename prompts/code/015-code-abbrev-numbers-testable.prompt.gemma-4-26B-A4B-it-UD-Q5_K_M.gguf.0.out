<channel|>```python
def abbrev_num(x):
    if x < 1000:
        return str(x)
    
    # Define the suffixes and their corresponding divisors
    suffixes = [
        (10**9, 'B'),
        (10**6, 'M'),
        (10**3, 'K')
    ]
    
    for limit, suffix in suffixes:
        if x >= limit:
            val = x / limit
            # Try 1 decimal place (e.g., 8.2K)
            # This results in 4 characters (digit, dot, digit, suffix)
            # We use round(val, 1) to get the significant digit
            rounded_val = round(val, 1)
            
            # Check if rounding to 1 decimal place keeps us within 4 chars
            # A float like 8.2 formatted as '8.2' is 3 chars. + 'K' = 4.
            # However, if rounded_val is an integer (e.g. 8.0), 
            # we should check if we can just use the integer to save space.
            
            s_val = f"{rounded_val:.1f}"
            # If the decimal is .0, strip it to save space/cleanliness
            if s_val.endswith('.0'):
                s_val = s_val[:-2]
            
            # If the resulting string + suffix is <= 4 chars, return it
            if len(s_val) + 1 <= 4:
                return f"{s_val}{suffix}"
            else:
                # Otherwise, fallback to integer rounding (e.g., 75K)
                return f"{round(val)}{suffix}"
                
    return str(x)
``` [end of text]


