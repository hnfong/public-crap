<!DOCTYPE html><html><head><title>Poker</title><style>body{font-family:sans-serif;text-align:center;background:#2c3e50;color:#ecf0f1}.card{display:inline-block;width:50px;height:75px;border:1px solid #fff;border-radius:5px;margin:5px;line-height:75px;font-size:20px;background:#fff;color:#000}.red{color:red}.hand{margin:10px;padding:10px;border:1px dashed #7f8c8d;display:inline-block}.btn{padding:10px 20px;font-size:16px;cursor:pointer;background:#e74c3c;color:#fff;border:none;border-radius:5px;margin:5px}.btn:disabled{background:#95a5a6}</style></head><body><h1>Video Poker</h1><div id="status">Deal to start</div><div id="hands"></div><div><button id="dealBtn" class="btn" onclick="deal()">Deal</button><button id="drawBtn" class="btn" onclick="draw()" disabled>Draw</button></div><script>const S=['♠','♥','♦','♣'],R=['2','3','4','5','6','7','8','9','T','J','Q','K','A'];let deck=[],hands=[],score=0;function mkDeck(){deck=[];for(let s of S)for(let r of R)deck.push({s,r,v:R.indexOf(r)+2});deck.sort(()=>Math.random()-0.5);}function val(c){return c.v;}function isFlush(h){return h.every(c=>c.s===h[0].s);}function isStraight(h){let v=h.map(val).sort((a,b)=>a-b);return v[4]-v[0]===4&&new Set(v).size===5||(v[0]===2&&v[1]===3&&v[2]===4&&v[3]===5&&v[4]===14);}function check(h){let v=h.map(val).sort((a,b)=>b-a);let counts={};v.forEach(x=>counts[x]=(counts[x]||0)+1);let c=Object.values(counts).sort((a,b)=>b-a);let flush=isFlush(h),straight=isStraight(h);if(flush&&straight&&v[0]===14&&v[4]===10)return'Royal Flush';if(flush&&straight)return'Straight Flush';if(c[0]===4)return'Four of a Kind';if(c[0]===3&&c[1]===2)return'Full House';if(flush)return'Flush';if(straight)return'Straight';if(c[0]===3)return'Three of a Kind';if(c[0]===2&&c[1]===2)return'Two Pair';if(c[0]===2)return'Pair';return'High Card';}function render(){let h=document.getElementById('hands');h.innerHTML='';hands.forEach((hand,idx)=>{let d=document.createElement('div');d.className='hand';d.innerHTML=`<b>Hand ${idx+1}</b><br>`;hand.forEach(c=>{let el=document.createElement('span');el.className='card'+(c.s==='♥'||c.s==='♦'?' red':'');el.textContent=c.s+c.r;d.appendChild(el);});h.appendChild(d);});document.getElementById('status').textContent=hands.length?check(hands[0]):'Deal to start';document.getElementById('drawBtn').disabled=!hands.length;}function deal(){mkDeck();hands=[deck.splice(0,5)];render();document.getElementById('dealBtn').disabled=true;document.getElementById('drawBtn').disabled=false;}function draw(){let h=hands[0];let keep=prompt('Indices to keep (0-4, comma separated, empty to discard all):');let keepIdx=keep?keep.split(',').map(Number).filter(i=>i>=0&&i<5):[];let newHand=[];for(let i=0;i<5;i++){if(keepIdx.includes(i))newHand.push(h[i]);else newHand.push(deck.pop());}hands=[newHand];render();document.getElementById('dealBtn').disabled=false;document.getElementById('drawBtn').disabled=true;}</script></body></html> [end of text]


