<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Card Clicker</title>
<style>
  body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; background: #222; color: #eee; }
  h1 { margin: 10px 0; }
  .game { display: flex; gap: 10px; }
  .card { width: 80px; height: 120px; background: #fff; border-radius: 8px; cursor: pointer; display: flex; flex-direction: column; justify-content: center; align-items: center; box-shadow: 0 4px 6px rgba(0,0,0,0.3); transition: transform 0.1s; user-select: none; }
  .card:hover { transform: translateY(-2px); }
  .card.selected { transform: translateY(-5px); box-shadow: 0 0 0 4px #00ff00; }
  .card.red { color: #ff4444; }
  .card.black { color: #4444ff; }
  .card span { font-size: 12px; }
  .controls { margin-top: 20px; }
  button { padding: 10px 20px; font-size: 16px; cursor: pointer; background: #444; color: #fff; border: none; border-radius: 4px; }
  button:hover { background: #666; }
</style>
</head>
<body>
<h1>Card Clicker</h1>
<div class="game" id="game"></div>
<div class="controls">
  <button onclick="resetGame()">Reset</button>
</div>
<script>
  const suits = ['♠','♥','♦','♣'];
  const colors = ['red','black'];
  let deck = [];
  let selected = null;
  let score = 0;
  let cards = [];

  function init() {
    deck = [];
    for(let s of suits) for(let c of colors) for(let i=0;i<13;i++) deck.push({s,suit:c,rank:i});
    shuffle(deck);
    cards = [];
    score = 0;
    selected = null;
    render();
  }

  function shuffle(array) {
    for(let i=array.length-1;i>0;i--) {
      const j = Math.floor(Math.random()*(i+1));
      [array[i],array[j]] = [array[j],array[i]];
    }
  }

  function render() {
    const container = document.getElementById('game');
    container.innerHTML = '';
    cards.forEach((c, i) => {
      const el = document.createElement('div');
      el.className = `card ${c.suit === '♥' || c.suit === '♦' ? 'red' : 'black'}`;
      el.onclick = () => {
        if(!selected) {
          selected = c;
          el.classList.add('selected');
        } else {
          selected.suit = c.suit;
          selected.rank = c.rank;
          selected = null;
          el.classList.remove('selected');
        }
        render();
      };
      el.innerHTML = `<span>${c.rank}${c.suit}</span>`;
      container.appendChild(el);
    });
  }

  function resetGame() {
    init();
  }

  init();
</script>
</body>
</html> [end of text]


