```python
def abbrev_num(x):
    if x < 1000:
        return str(x)
    elif x < 1_000_000:
        k = x / 1000
        if k >= 10:
            return f"{int(round(k))}K"
        else:
            return f"{k:.1f}K"
    else:
        m = x / 1_000_000
        if m >= 10:
            return f"{int(round(m))}M"
        else:
            return f"{m:.1f}M"
