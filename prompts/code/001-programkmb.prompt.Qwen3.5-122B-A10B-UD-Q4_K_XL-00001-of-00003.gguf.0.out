```java
import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class NumberSumCalculator {
    public static void main(String[] args) throws IOException {
        BufferedReader reader = new BufferedReader(new InputStreamReader(System.in));
        StringBuilder inputBuilder = new StringBuilder();
        String line;

        while ((line = reader.readLine()) != null) {
            inputBuilder.append(line).append("\n");
        }

        String input = inputBuilder.toString();
        double totalSum = 0.0;

        // Pattern explanation:
        // \d{1,3}(?:,\d{3})* : Matches numbers with commas (e.g., 1,000,000)
        // \.\d+              : Optional decimal part
        // [kKmMgG]?          : Optional suffix
        Pattern pattern = Pattern.compile("(\\d{1,3}(?:,\\d{3})*(?:\\.\\d+)?|[0-9]+(?:\\.\\d+)?)([kKmMgG])?");
        Matcher matcher = pattern.matcher(input);

        while (matcher.find()) {
            String numberPart = matcher.group(1);
            String suffix = matcher.group(2);

            // Remove commas from the number part
            String cleanNumber = numberPart.replace(",", "");
            double value = Double.parseDouble(cleanNumber);

            if (suffix != null) {
                char s = suffix.toLowerCase().charAt(0);
                switch (s) {
                    case 'k':
                        value *= 1024;
                        break;
                    case 'm':
                        value *= 1024 * 1024;
                        break;
                    case 'g':
                        value *= 1024 * 1024 * 1024;
                        break;
                }
            }

            totalSum += value;
        }

        // Calculate sums in different units
        double sumK = totalSum / 1024.0;
        double sumM = totalSum / (1024.0 * 1024.0);
        double sumG = totalSum / (1024.0 * 1024.0 * 1024.0);

        // Print results formatted to one decimal place
        System.out.printf("%.1f%n", totalSum);
        System.out.printf("%.1f k%n", sumK);
        System.out.printf("%.1f M%n", sumM);
        System.out.printf("%.1f G%n", sumG);
    }
}
