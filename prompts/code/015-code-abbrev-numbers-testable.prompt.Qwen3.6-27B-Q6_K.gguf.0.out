```python
def abbrev_num(x):
    """
    Convert an integer to a compact, human-readable string representation.
    
    Examples:
        2 => "2"
        8180 => "8.2K"
        9385832 => "9.4M"
        74581 => "75K"
    
    The output string should be <= 4 characters if at all possible.
    """
    if x < 0:
        return "-" + abbrev_num(-x)
    
    if x < 1000:
        return str(x)
    
    if x < 1_000_000:
        # Thousands
        # Try with one decimal place first: e.g., 8.2K (4 chars)
        # If that exceeds 4 chars, round to nearest thousand
        val = x / 1000.0
        # Format with one decimal
        formatted = f"{val:.1f}K"
        if len(formatted) <= 4:
            return formatted
        else:
            # Round to nearest thousand, no decimal
            rounded = round(x / 1000)
            return f"{rounded}K"
    
    if x < 1_000_000_000:
        # Millions
        val = x / 1_000_000.0
        formatted = f"{val:.1f}M"
        if len(formatted) <= 4:
            return formatted
        else:
            rounded = round(x / 1_000_000)
            return f"{rounded}M"
    
    if x < 1_000_000_000_000:
        # Billions
        val = x / 1_000_000_000.0
        formatted = f"{val:.1f}B"
        if len(formatted) <= 4:
            return formatted
        else:
            rounded = round(x / 1_000_000_000)
            return f"{rounded}B"
    
    # Trillions
    val = x / 1_000_000_000_000.0
    formatted = f"{val:.1f}T"
    if len(formatted) <= 4:
        return formatted
    else:
        rounded = round(x / 1_000_000_000_000)
        return f"{rounded}T"
