```java
import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.ArrayList;
import java.util.List;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class NumberConverter {

    private static final double K = 1024.0;
    private static final double M = K * K;
    private static final double G = M * K;

    public static void main(String[] args) {
        try (BufferedReader reader = new BufferedReader(new InputStreamReader(System.in))) {
            String line;
            List<Double> numbers = new ArrayList<>();

            while ((line = reader.readLine()) != null) {
                line = line.trim();
                if (line.isEmpty()) {
                    continue;
                }

                String[] parts = line.split("[,\\s]+");
                for (String part : parts) {
                    part = part.trim();
                    if (part.isEmpty()) {
                        continue;
                    }

                    double value = parseNumber(part);
                    if (value != null) {
                        numbers.add(value);
                    }
                }
            }

            double total = 0;
            for (double num : numbers) {
                total += num;
            }

            System.out.printf("%.1f%n", total);
            System.out.printf("%.1f k%n", total / K);
            System.out.printf("%.1f M%n", total / M);
            System.out.printf("%.1f G%n", total / G);
        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    private static Double parseNumber(String number) {
        // Remove commas (thousand separators)
        number = number.replace(",", "");

        // Remove optional suffixes (k, K, m, M, g, G)
        number = number.toLowerCase().replaceAll("[kKmMgG]$", "");

        // Check if it's a valid number
        if (number.isEmpty()) {
            return null;
        }

        // Check if it's a decimal number
        if (number.indexOf('.') >= 0) {
            return Double.parseDouble(number);
        }

        // Check if it's an integer
        try {
            return Double.parseDouble(number);
        } catch (NumberFormatException e) {
            return null;
        }
    }
}
